# Server
NODE_ENV=development
PORT=3000
API_BASE_PATH=/api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/arena

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Password reset (optional - use a token expiry in seconds)
PASSWORD_RESET_EXPIRY=3600

# Cloudinary (for media URLs - app can upload directly; backend may sign or proxy)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase Admin (for verifying Google/social ID tokens)
# From Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS - comma-separated origins (use * for dev only)
CORS_ORIGINS=http://localhost:8080,https://your-app.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
